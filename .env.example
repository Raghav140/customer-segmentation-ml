# Application Settings
APP_NAME=Customer Segmentation System
APP_VERSION=1.0.0
ENVIRONMENT=development

# Data Configuration
DATA_RAW_PATH=data/raw
DATA_PROCESSED_PATH=data/processed
DATA_EXTERNAL_PATH=data/external
DATA_MAX_FILE_SIZE_MB=100

# Model Configuration
MODEL_MODELS_PATH=models
MODEL_PRODUCTION_MODELS_PATH=models/production
MODEL_STAGING_MODELS_PATH=models/staging
MODEL_KMEANS_MAX_CLUSTERS=10
MODEL_KMEANS_RANDOM_STATE=42
MODEL_KMEANS_N_INIT=10
MODEL_HIERARCHICAL_LINKAGE=ward
MODEL_HIERARCHICAL_METRIC=euclidean
MODEL_PCA_VARIANCE_THRESHOLD=0.95
MODEL_PCA_RANDOM_STATE=42

# Evaluation Configuration
EVAL_METRICS=silhouette_score,davies_bouldin_score,calinski_harabasz_score
EVAL_CV_FOLDS=5

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RATE_LIMIT_PER_MINUTE=60
API_SECRET_KEY=your-secret-key-here
API_ALGORITHM=HS256
API_ACCESS_TOKEN_EXPIRE_MINUTES=30

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=customer-segmentation
MLFLOW_AUTOLOG=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/app.log
LOG_MAX_FILE_SIZE_MB=10
LOG_BACKUP_COUNT=5
